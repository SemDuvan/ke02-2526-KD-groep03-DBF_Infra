# --- Azure Credentials ---
# Vul hieronder de gegevens in van je Azure Service Principal
# Deze vind je in de Azure Portal onder Microsoft Entra ID -> App Registrations
export ARM_CLIENT_ID="JOUW_CLIENT_ID"
export ARM_CLIENT_SECRET="JOUW_CLIENT_SECRET"
export ARM_SUBSCRIPTION_ID="JOUW_SUBSCRIPTION_ID"
export ARM_TENANT_ID="JOUW_TENANT_ID"

# --- Terraform Variabelen ---
# Hiermee overschrijf je de 'default' waarde in je main.tf
export TF_VAR_resource_group_naam="ke02-2526-KD-groep03"

echo "✅ Azure credentials en variabelen zijn geladen!"
echo "Je kunt nu 'terraform init' of 'terraform plan' uitvoeren."
